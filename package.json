{
  "name": "chess-openings",
  "version": "1.5.1",
  "description": "Chess Opening Trainer — free, offline, open source",
  "author": "primewaypoint",
  "license": "GPL-3.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac --win",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.chessopenings.app",
    "productName": "ChessOpenings",
    "files": ["renderer/**/*", "assets/**/*", "main.js"],
    "mac": {
      "target": [{"target": "dmg", "arch": ["arm64", "x64"]}],
      "icon": "assets/icon.png",
      "identity": null
    },
    "win": {
      "target": [{"target": "nsis", "arch": ["x64"]}],
      "icon": "assets/icon.png"
    }
  }
}
